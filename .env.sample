# ─────────────────────────────────────────────────────────────
# Polymarket CLOB API Credentials
# ─────────────────────────────────────────────────────────────
# Get these from https://polymarket.com/settings → API
#
# For POLY_PROXY (Magic Link / Google auth users):
#   1. Sign in at polymarket.com
#   2. Go to Settings → API → Create API Key
#   3. Copy the values below

# Wallet private key for EIP-712 order signing.
# Must match the wallet that owns the API credentials.
# Format: hex string with or without 0x prefix.
PRIVATE_KEY=""

# Funder address — your proxy wallet address (POLY_PROXY).
# For Magic Link users, this is your Polymarket proxy address.
# Found in Settings → Profile or via create-proxy endpoint.
FUNDER=""

# API key UUID (from Polymarket API settings).
POLYMARKET_KEY=""

# API secret (for HMAC-SHA256 L2 authentication).
POLYMARKET_SECRET=""

# API passphrase.
POLYMARKET_PASSPHRASE=""

# ─────────────────────────────────────────────────────────────
# Optional overrides
# ─────────────────────────────────────────────────────────────

# CLOB API base URL (default: https://clob.polymarket.com)
# POLY_CLOB_URL="https://clob.polymarket.com"

# Signature type: 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE, 3=POLY_1271
# Default: 1 (POLY_PROXY)
# POLY_SIGNATURE_TYPE=1
